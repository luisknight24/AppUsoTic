<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8">

    <ImageView
        android:id="@+id/imageViewCienAnios"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.7"
        app:layout_constraintDimensionRatio="16:9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/cienanios" />

    <TextView
        android:id="@+id/txtTituloCienAnios"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Actividad sobre Cien años de soledad"
        android:textSize="50sp"
        android:layout_marginTop="50dp"
        app:layout_constraintBottom_toTopOf="@id/btnAhorcadoCienAnios"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:fontFamily="sans-serif-black"
        android:textColor="#000000"
        android:textAlignment="center"/>

    <Button
        android:id="@+id/btnAhorcadoCienAnios"
        android:layout_width="400px"
        android:layout_height="wrap_content"
        android:text="El ahorcado"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtTituloCienAnios"
        android:layout_marginTop="50dp"
        android:textColor="#FFFF"
        android:backgroundTint="#6750A4"/>

    <Button
        android:id="@+id/btnRegresarCienAnios"
        android:layout_width="400px"
        android:layout_height="wrap_content"
        android:text="Regresar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnAhorcadoCienAnios"
        android:layout_marginTop="50dp"
        android:textColor="#FFFF"
        android:backgroundTint="#6750A4"/>

</androidx.constraintlayout.widget.ConstraintLayout>